      "sc_name",
      "uid",
      "stu_gov_id",
      "first_name",
      "last_name",
      "attempt_id",
      "twtar_id",
      "window_code",
      "long_name",
      "type_slug",
      "lang"
    ],
    "methodConfig": {
      "sequence": [
        {
          "kind": "join",
          "df_output": "df",
          "config": {
            "how": "inner",
            "left": "attempts",
            "right": "students",
            "left_on": "uid",
            "right_on": "uid"
          }
        },
        {
          "kind": "restrict-cols",
          "df_output": "twtar",
          "config": {
            "df_input": "twtar",
            "cols": [
              "test_window_id",
              "twtar_id",
              "window_code",
              "long_name",
              "type_slug",
              "lang"
            ]
          }
        },
        {
          "kind": "join",
          "df_output": "df",
          "config": {
            "how": "inner",
            "left": "df",
            "right": "twtar",
            "left_on": "twtar_id",
            "right_on": "twtar_id"
          }
        },
        {
          "kind": "join",
          "df_output": "df",
          "config": {
            "how": "inner",
            "left": "df",
            "right": "load_tw",
            "left_on": "test_window_id",
            "right_on": "test_window_id"
          }
        },
        {
          "kind": "restrict-cols",
          "df_output": "df",
          "config": {
            "df_input": "df",
            "cols": [
              "test_window_id",
              "tw_type_slug",
              "s_gid",
              "s_name",
              "sc_gid",
              "sc_name",
              "uid",
              "stu_gov_id",
              "first_name",
              "last_name",
              "attempt_id",
              "twtar_id",
              "window_code",
              "long_name",
              "type_slug",
              "lang"
            ]
          }
        }
      ],
      "output": "df"
    },
    "dependencySourcings": [
      {
        "param": "attempts",
        "type": "dataframe",
        "config": {
          "asset": "trfm_ta_in_sb"
        }
