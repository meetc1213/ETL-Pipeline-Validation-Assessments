            "cols": [
              "attempt_id",
              "uid",
              "twtar_id",
              "ts_id",
              "test_form_id"
            ]
          }
        },
        {
          "kind": "filter-col",
          "df_output": "test_attempts",
          "config": {
            "df_input": "test_attempts",
            "col": "attempt_id",
            "comparison": "in",
            "value_src": {
              "df": "item_responses",
              "col": "ta_id"
            }
          }
        },
        {
          "kind": "restrict-cols",
          "df_output": "twtar",
          "config": {
            "df_input": "twtar",
            "cols": [
              "twtar_id",
              "td_id",
              "test_window_id",
              "type_slug",
              "form_code",
              "window_code"
            ]
          }
        },
        {
          "kind": "join",
          "df_output": "test_attempts",
          "config": {
            "how": "inner",
            "left": "test_attempts",
            "right": "twtar",
            "left_on": "twtar_id",
            "right_on": "twtar_id"
          }
        },
        {
          "kind": "restrict-cols",
          "df_output": "tqr",
          "config": {
            "df_input": "tqr",
            "cols": [
              "test_design_id",
              "item_id",
              "response_lang",
              "item_nbr",
              "item_domain"
            ]
          }
        },
        {
          "kind": "join",
          "df_output": "test_attempts",
          "config": {
            "how": "inner",
            "left": "test_attempts",
            "right": "tqr",
            "left_on": "td_id",
            "right_on": "test_design_id"
          }
        },
        {
          "kind": "sort-by",
          "df_output": "test_attempts",
          "config": {
            "df_input": "test_attempts",
            "cols": [
              "attempt_id",
              "item_nbr",
              "item_id"
            ],
            "ascending": [
              true,
              true,
              true
            ]
          }
        },
        {
          "kind": "join",
          "df_output": "item_responses",
          "config": {
            "how": "left",
            "left": "test_attempts",
            "right": "item_responses",
            "left_on": [
              "attempt_id",
              "item_id"
            ],
            "right_on": [
              "ta_id",
              "item_id"
            ]
          }
        },
        {
          "kind": "fill-na",
          "df_output": "item_responses",
          "config": {
            "df_input": "item_responses",
            "values": {
              "score": 0,
              "is_nr": 1,
              "is_invalid": 0,
              "formatted_response": "",
              "formatted_response_strict": "",
              "response_type": "",
              "is_score_override": 0
            },
            "inplace": true
          }
        },
        {
          "kind": "rename-cols",
          "df_output": "item_responses",
          "config": {
            "df_input": "item_responses",
            "new_names": {
              "ta_id": "test_attempt_id",
              "td_id": "test_design_id",
              "weight": "score_max",
              "type_slug": "asmt_code"
            }
          }
        }
      ],
      "output": "item_responses"
    },
    "dependencySourcings": [
      {
        "param": "item_responses",
        "type": "dataframe",
        "config": {
          "asset": "trfm_responses_with_domain"
        }
      },
      {
        "param": "tqr",
        "type": "dataframe",
        "config": {
          "asset": "load_item_register_consolidated"
        }
      },
